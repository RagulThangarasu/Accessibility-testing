{
  "name": "accessibility-scanner",
  "version": "1.0.0",
  "description": "Enter any URL, scan it for WCAG 2.0 AA accessibility issues, and generate an HTML/PDF report.",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.js",
    "scan": "node --env-file-if-exists=.env src/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@axe-core/playwright": "^4.10.1",
    "@siteimprove/alfa-act": "^0.118.0",
    "@siteimprove/alfa-dom": "^0.118.0",
    "@siteimprove/alfa-playwright": "^0.84.1",
    "@siteimprove/alfa-rules": "^0.118.0",
    "@siteimprove/alfa-wcag": "^0.118.0",
    "express": "^4.21.2",
    "html_codesniffer": "^2.5.1",
    "html-validate": "^11.5.3",
    "playwright": "^1.49.1"
  }
}
