{
  "name": "accessibility-scanner",
  "version": "1.0.0",
  "description": "Accessibility scanning tool with web crawling, WCAG compliance testing, and PDF report generation",
  "main": "src/scanner.js",
  "type": "module",
  "scripts": {
    "scan": "node src/scanner.js",
    "dev": "node src/server.js",
    "build": "npm run build:frontend",
    "build:frontend": "cp -r public/* docs/",
    "test": "node src/scanner.js --url https://example.com --level AA"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@siteimprove/alfa-act": "^0.117.0",
    "@siteimprove/alfa-aria": "^0.117.0",
    "@siteimprove/alfa-cascade": "^0.117.0",
    "@siteimprove/alfa-dom": "^0.117.0",
    "@siteimprove/alfa-playwright": "^0.84.0",
    "@siteimprove/alfa-rules": "^0.117.0",
    "@siteimprove/alfa-wcag": "^0.117.0",
    "axe-core": "^4.8.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ora": "^7.0.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.60.0",
    "puppeteer": "^21.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "accessibility",
    "wcag",
    "a11y",
    "scanner",
    "audit"
  ],
  "author": "",
  "license": "MIT"
}
